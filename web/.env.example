VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# OAuth return URL — must match an entry in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs (same scheme/host/port as Vite, usually ends with /). If unset, defaults to window.location.origin + /
# VITE_AUTH_CALLBACK_URL=http://localhost:5173/
# Optional: defaults to http://127.0.0.1:7777
# VITE_ENGINE_URL=http://127.0.0.1:7777
