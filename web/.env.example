VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# OAuth return URL — must exactly match an entry in Supabase → Authentication → URL Configuration → Redirect URLs.
# Must use the SAME origin you use in the browser (same scheme, host, port): e.g. http://127.0.0.1:5173/ when using Vite on 5173,
# or https://your-app.vercel.app/ for production. Wrong port (e.g. :3847) causes ERR_CONNECTION_REFUSED after Google login.
# Leave commented to auto-use the current page origin (recommended for dev).
# VITE_AUTH_CALLBACK_URL=http://localhost:5173/
# Optional: defaults to http://127.0.0.1:7777
# VITE_ENGINE_URL=http://127.0.0.1:7777
