{
  "name": "@ctrack/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "bundle": "ncc build src/server.ts -o dist-bundle -m --external better-sqlite3",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts --max-warnings 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/lib-storage": "^3.978.0",
    "@supabase/supabase-js": "^2.93.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mp4box": "^2.3.0",
    "multer": "^1.4.5-lts.1",
    "python-shell": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
